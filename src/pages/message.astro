---
import MainLayout from "../layouts/MainLayout.astro";
import headerHtml from "../partials/main/message-header.html?raw";
import contentHtml from "../partials/main/message-content.html?raw";
import scriptsHtml from "../partials/main/message-scripts.html?raw";

const title = "ごあいさつ | 有限会社まるよし工業";
const description = `未来のまるよしの工業ため。
まるよし工業は昭和48年、父・工藤喜博が創業しました。鐵骨建設、製缶、配管など、鐵構関連の工事を受注する会社です。`;
const bodyClass =
  "style-simple layout-full-width mobile-tb-left if-overlay no-content-padding header-classic header-fw minimalist-header sticky-header sticky-white ab-hide subheader-title-left menu-line-below menuo-right menuo-no-borders";
---

<MainLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  includeRsPluginCss={false}
  headerHtml={headerHtml}
  contentHtml={contentHtml}
  scriptsHtml={scriptsHtml}
  footerCurrent="about"
/>
